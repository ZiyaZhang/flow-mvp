{
  "name": "flow-mvp-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "build:server": "tsup apps/server/src/index.ts --format esm --target node22 --out-dir apps/server/dist --clean",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run build:server && npm run build:web",
    "start": "node apps/server/dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
